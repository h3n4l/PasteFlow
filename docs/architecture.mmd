    style CREATE_ITEM fill:#FF6B6B,color:#fff
    style PASTE_SIM fill:#7B68EE,color:#fff
    style INIT fill:#EBF5FB,color:#333
    style REACTIVE fill:#FEF9E7,color:#333
    style DB fill:#E8F8F5,color:#333
